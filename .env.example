# =====================================================================
# metu — environment variables
# Copy to .env.local and fill in. Never commit .env.local.
# =====================================================================

# ----- Core
NODE_ENV=development
AUTH_SECRET=                                 # openssl rand -base64 32
AUTH_URL=http://localhost:24890

# ----- Database (Neon Postgres + pgvector)
DATABASE_URL=postgres://user:pass@ep-xxx.neon.tech/metu?sslmode=require
DIRECT_URL=postgres://user:pass@ep-xxx.neon.tech/metu?sslmode=require

# ----- Google OAuth (web sign-in)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ----- Encryption (envelope key for BYOK secrets)
# 32 bytes base64. Real prod: pull from GCP Secret Manager.
ENCRYPTION_KEY=

# ----- GCP
GCP_PROJECT_ID=metu-prod-495423
GCP_REGION=europe-west1
GCS_BUCKET=metu-prod-uploads
# Public-read bucket for avatars + workspace logos. Configure with Uniform
# Bucket-Level Access + an IAM binding granting `roles/storage.objectViewer`
# to `allUsers`. Locally, point GCS_PUBLIC_BASE_URL at MinIO + create a
# public bucket policy.
GCS_PUBLIC_BUCKET=metu-public
GCS_PUBLIC_BASE_URL=
GOOGLE_APPLICATION_CREDENTIALS=./gcp-sa.json   # local dev only

# ----- Upstash Redis (queue + ratelimit + cache)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ----- Inngest (workflows)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ----- AI providers
# NOTE: Anthropic / OpenAI / Google / Azure API keys are NOT stored here.
# Add them per-workspace via Settings → AI providers (BYOK). They are sealed
# with AES-256-GCM using ENCRYPTION_KEY and stored in the provider_credential table.

# ----- Integrations
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
# Enables 1-click "Sign in with GitHub" device flow on /integrations.
# Use the client_id of any GitHub App or OAuth App you own (device flow must
# be enabled in the App's settings). Leave blank to fall back to PAT entry.
GITHUB_OAUTH_CLIENT_ID=

# Enables full browser OAuth ("Sign in with <Provider>") for built-in
# integrations. Set both ID and SECRET. Each provider's redirect URI is
#   {AUTH_URL}/api/integrations/oauth/<kind>/callback
# e.g. http://localhost:24890/api/integrations/oauth/github/callback
GITHUB_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
VERCEL_OAUTH_CLIENT_ID=
VERCEL_OAUTH_CLIENT_SECRET=
SLACK_OAUTH_CLIENT_ID=
SLACK_OAUTH_CLIENT_SECRET=
NOTION_OAUTH_CLIENT_ID=
NOTION_OAUTH_CLIENT_SECRET=
LINEAR_OAUTH_CLIENT_ID=
LINEAR_OAUTH_CLIENT_SECRET=
SPOTIFY_OAUTH_CLIENT_ID=
SPOTIFY_OAUTH_CLIENT_SECRET=
STRIPE_OAUTH_CLIENT_ID=
TELEGRAM_BOT_TOKEN=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Stripe Price IDs → metu subscription tier mapping (cap in $/month)
# Leave blank to disable that tier in the Settings → Billing UI.
STRIPE_PRICE_STARTER=          # $9/mo  → $3 voice cap
STRIPE_PRICE_PRO=              # $29/mo → $15 voice cap
STRIPE_PRICE_PRO_PLUS=         # $79/mo → $50 voice cap
STRIPE_PRICE_ENTERPRISE=       # $249/mo → $200 voice cap

# ----- Worker (Cloud Run)
WORKER_URL=http://localhost:24892
WORKER_AUTH_TOKEN=                           # shared secret web<->worker

# ----- Mobile / public
NEXT_PUBLIC_APP_URL=http://localhost:24890
NEXT_PUBLIC_APP_NAME=metu
