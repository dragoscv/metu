# =====================================================================
# metu — environment variables
# Copy to .env.local and fill in. Never commit .env.local.
# =====================================================================

# ----- Core
NODE_ENV=development
AUTH_SECRET=                                 # openssl rand -base64 32
AUTH_URL=http://localhost:24890

# ----- Database (Neon Postgres + pgvector)
DATABASE_URL=postgres://user:pass@ep-xxx.neon.tech/metu?sslmode=require
DIRECT_URL=postgres://user:pass@ep-xxx.neon.tech/metu?sslmode=require

# ----- Google OAuth (web sign-in)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ----- Encryption (envelope key for BYOK secrets)
# 32 bytes base64. Real prod: pull from GCP Secret Manager.
ENCRYPTION_KEY=

# ----- GCP
GCP_PROJECT_ID=metu-prod-495423
GCP_REGION=europe-west1
GCS_BUCKET=metu-prod-uploads
# Public-read bucket for avatars + workspace logos. Configure with Uniform
# Bucket-Level Access + an IAM binding granting `roles/storage.objectViewer`
# to `allUsers`. Locally, point GCS_PUBLIC_BASE_URL at MinIO + create a
# public bucket policy.
GCS_PUBLIC_BUCKET=metu-public
GCS_PUBLIC_BASE_URL=
GOOGLE_APPLICATION_CREDENTIALS=./gcp-sa.json   # local dev only

# ----- Upstash Redis (queue + ratelimit + cache)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ----- Inngest (workflows)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ----- AI providers
# NOTE: Anthropic / OpenAI / Google / Azure API keys are NOT stored here.
# Add them per-workspace via Settings → AI providers (BYOK). They are sealed
# with AES-256-GCM using ENCRYPTION_KEY and stored in the provider_credential table.

# ----- Integrations
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
# Enables 1-click "Sign in with GitHub" device flow on /integrations.
# Use the client_id of any GitHub App or OAuth App you own (device flow must
# be enabled in the App's settings). Leave blank to fall back to PAT entry.
GITHUB_OAUTH_CLIENT_ID=

# Enables full browser OAuth ("Sign in with <Provider>") for built-in
# integrations. Set both ID and SECRET. Each provider's redirect URI is
#   {AUTH_URL}/api/integrations/oauth/<kind>/callback
# e.g. http://localhost:24890/api/integrations/oauth/github/callback
GITHUB_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
VERCEL_OAUTH_CLIENT_ID=
VERCEL_OAUTH_CLIENT_SECRET=
SLACK_OAUTH_CLIENT_ID=
SLACK_OAUTH_CLIENT_SECRET=
NOTION_OAUTH_CLIENT_ID=
NOTION_OAUTH_CLIENT_SECRET=
LINEAR_OAUTH_CLIENT_ID=
LINEAR_OAUTH_CLIENT_SECRET=
SPOTIFY_OAUTH_CLIENT_ID=
SPOTIFY_OAUTH_CLIENT_SECRET=
STRIPE_OAUTH_CLIENT_ID=
TELEGRAM_BOT_TOKEN=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ----- Codai (auth.codai.ro) "Connect with Codai" OAuth
# Public PKCE client — no client secret. The callback exchanges the code at
# {CODAI_AUTH_URL}/token then mints a scoped inference key via
# {CODAI_AUTH_URL}/connect/key and stores it as the workspace codai provider
# credential. Register METU's redirect URI on codai with:
#   .../api/integrations/oauth/codai/callback
CODAI_AUTH_URL=https://auth.codai.ro
CODAI_OAUTH_CLIENT_ID=metu
# Stripe Price IDs → metu subscription tier mapping (cap in $/month)
# Leave blank to disable that tier in the Settings → Billing UI.
STRIPE_PRICE_STARTER=          # $9/mo  → $3 voice cap
STRIPE_PRICE_PRO=              # $29/mo → $15 voice cap
STRIPE_PRICE_PRO_PLUS=         # $79/mo → $50 voice cap
STRIPE_PRICE_ENTERPRISE=       # $249/mo → $200 voice cap

# ----- Worker (Cloud Run)
WORKER_URL=http://localhost:24892
WORKER_AUTH_TOKEN=                           # shared secret web<->worker

# ----- Mobile / public
NEXT_PUBLIC_APP_URL=http://localhost:24890
NEXT_PUBLIC_APP_NAME=metu

# ----- Realtime hub (apps/hub)
# Web ↔ hub share HUB_INTERNAL_SECRET via the x-hub-secret header.
# WEB_INTERNAL_URL is the address the hub posts tool.result envelopes to.
HUB_PORT=24891
HUB_INTERNAL_URL=http://localhost:24891
HUB_INTERNAL_SECRET=                           # openssl rand -hex 32
WEB_INTERNAL_URL=http://localhost:24890
# Per-IP connection cap. Default fine for prod behind a CDN/LB.
HUB_MAX_CONNECTIONS=200

# ----- Web push (VAPID)
# Generate with: npx web-push generate-vapid-keys
# Leave blank to gracefully no-op push notifications in dev.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# ----- Expo push (mobile native notifications)
EXPO_ACCESS_TOKEN=

# ----- Email (Resend) — digests + notifications
RESEND_API_KEY=
RESEND_FROM=metu <noreply@metu.ro>

# ----- Telegram bot (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=                     # openssl rand -hex 24
WEBHOOK_PUBLIC_URL=                          # public https URL for webhook registration

# ----- Hub tuning (optional; sane defaults)
HUB_URL=ws://localhost:24891
HUB_HANDSHAKE_RATE=30
HUB_MSG_RATE=120
HUB_MAX_FRAME_BYTES=262144

# ----- MCP server (apps/mcp-server)
METU_WEB_URL=http://localhost:24890
METU_MCP_PUBLIC_URL=                         # public URL of /mcp (RFC 9728 resource)
METU_MCP_HTTP_PORT=                          # set to enable streamable HTTP
METU_API_TOKEN=                              # stdio single-token mode (metu_at_*)

# ----- Observability (optional)
LOG_LEVEL=info
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0

# ----- Dev/E2E only (never set in production)
E2E_AUTH_SECRET=                             # enables POST /api/dev/e2e-login

# ----- Companion (Tauri) — public client id
# Must match the oauth_client row that companion uses for device-code flow.
METU_COMPANION_CLIENT_ID=metu_app_companion

# ----- Master encryption key (key rotation / re-seal)
# 32 bytes base64. Used when re-sealing sealed secrets across key versions.
MASTER_ENCRYPTION_KEY=

# ----- Sentry (observability)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# Source-map upload at build time (optional — readable stack traces).
# Create an org auth token in Sentry → Settings → Auth Tokens.
SENTRY_ORG=metu-kj
SENTRY_PROJECT=metu
SENTRY_AUTH_TOKEN=

# ----- Dev-only cross-client bearer
# Used by scripts/local tooling to call /api/sdk/v1/* with a fixed token.
# Never set these in production.
METU_DEV_API_TOKEN=
METU_DEV_WORKSPACE_ID=
METU_DEV_USER_ID=

# ----- Email (SMTP)
SMTP_URL=
EMAIL_FROM=metu <noreply@example.com>
