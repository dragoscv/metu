{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "METU Companion",
  "version": "0.0.1",
  "identifier": "app.metu.companion",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "METU",
        "width": 860,
        "height": 560,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "visible": true,
        "shadow": false,
        "minWidth": 760,
        "minHeight": 520
      },
      {
        "label": "hud",
        "title": "METU HUD",
        "url": "index.html#hud",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "maximized": true,
        "visible": false,
        "focus": false
      },
      {
        "label": "assistant",
        "title": "METU Assistant",
        "url": "index.html#assistant",
        "width": 380,
        "height": 560,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "focus": false,
        "shadow": false
      },
      {
        "label": "overlay",
        "title": "METU Overlay",
        "url": "index.html#overlay",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "maximized": true,
        "visible": false,
        "focus": false,
        "shadow": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: https:; connect-src 'self' http://localhost:24890 http://localhost:24891 ws://localhost:24891 https://*.metu.app wss://*.metu.app; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "app", "dmg", "appimage", "deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "Your METU companion.",
    "longDescription": "Always-on desktop companion for METU — notifications, capture, and tools.",
    "publisher": "METU",
    "homepage": "https://metu.app",
    "copyright": "Copyright © METU",
    "createUpdaterArtifacts": "v1Compatible",
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "displayLanguageSelector": false,
        "languages": ["English"]
      },
      "allowDowngrades": true
    },
    "macOS": {
      "minimumSystemVersion": "10.15",
      "dmg": {
        "appPosition": { "x": 180, "y": 170 },
        "applicationFolderPosition": { "x": 480, "y": 170 },
        "windowSize": { "width": 660, "height": 400 }
      }
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      },
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0"]
      }
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["metu"]
      }
    },
    "updater": {
      "active": false,
      "endpoints": ["https://releases.metu.app/companion/latest.json"],
      "dialog": false,
      "pubkey": ""
    }
  }
}
