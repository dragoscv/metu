{
  "name": "@metu/hub",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch --env-file=../../.env.local src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@metu/db": "workspace:*",
    "@metu/auth": "workspace:*",
    "@metu/logger": "workspace:*",
    "@metu/protocol": "workspace:*",
    "drizzle-orm": "catalog:",
    "hono": "catalog:",
    "@hono/node-server": "catalog:",
    "ws": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@metu/config": "workspace:*",
    "@types/node": "catalog:",
    "@types/ws": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
