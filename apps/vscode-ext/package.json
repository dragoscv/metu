{
  "name": "metu-vscode",
  "displayName": "metu",
  "description": "Two-way bridge between VS Code and your second brain.",
  "version": "0.0.1",
  "publisher": "metu",
  "license": "MIT",
  "homepage": "https://metu.ro",
  "repository": {
    "type": "git",
    "url": "https://github.com/metu-app/metu.git",
    "directory": "apps/vscode-ext"
  },
  "bugs": {
    "url": "https://github.com/metu-app/metu/issues"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "AI",
    "Other"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "metu.capture",
        "title": "metu: Capture selection",
        "category": "metu"
      },
      {
        "command": "metu.recall",
        "title": "metu: Recall from memory",
        "category": "metu"
      },
      {
        "command": "metu.recallPanel",
        "title": "metu: Open recall panel",
        "category": "metu"
      },
      {
        "command": "metu.resume",
        "title": "metu: Where did I leave off?",
        "category": "metu"
      },
      {
        "command": "metu.regenerateBrief",
        "title": "metu: Regenerate project brief",
        "category": "metu"
      },
      {
        "command": "metu.notify",
        "title": "metu: Send notification",
        "category": "metu"
      },
      {
        "command": "metu.companionTurn",
        "title": "metu: Ask companion",
        "category": "metu"
      },
      {
        "command": "metu.refreshBacklog",
        "title": "metu: Refresh conductor backlog",
        "category": "metu",
        "icon": "$(refresh)"
      },
      {
        "command": "metu.signIn",
        "title": "metu: Sign in",
        "category": "metu"
      },
      {
        "command": "metu.signOut",
        "title": "metu: Sign out",
        "category": "metu"
      }
    ],
    "configuration": {
      "title": "metu",
      "properties": {
        "metu.apiUrl": {
          "type": "string",
          "default": "https://app.metu.ro",
          "description": "Base URL of your metu instance. The access token is stored in VS Code's SecretStorage and is not exposed here."
        },
        "metu.hubUrl": {
          "type": "string",
          "default": "wss://hub.metu.ro",
          "description": "WebSocket URL of the metu hub. The extension connects here on sign-in to receive editor.* tool invocations from the Conductor."
        },
        "metu.copilotBridge": {
          "type": "boolean",
          "default": true,
          "description": "Allow the Conductor to invoke your local Copilot language model via the editor.copilot_chat tool. Requires GitHub Copilot to be installed and signed in."
        },
        "metu.oauthClientId": {
          "type": "string",
          "default": "",
          "description": "OAuth client_id for the device-authorization flow. When set, 'metu: Sign in' uses RFC 8628 device flow instead of the manual paste fallback."
        },
        "metu.scopes": {
          "type": "string",
          "default": "openid profile capture:write recall:read notify:write event:read",
          "description": "Space-separated OAuth scopes requested during sign-in."
        },
        "metu.defaultPersona": {
          "type": "string",
          "default": "metu",
          "description": "Built-in persona slug used by 'metu: Ask companion'. Common values: metu, fox, owl."
        },
        "metu.captureOnSave": {
          "type": "boolean",
          "default": false,
          "description": "When enabled, every saved file in a workspace folder posts a small `code` capture into metu (file path + first 200 chars). Off by default to respect noise."
        }
      }
    },
    "keybindings": [
      {
        "command": "metu.capture",
        "key": "ctrl+alt+m",
        "mac": "cmd+alt+m"
      },
      {
        "command": "metu.recall",
        "key": "ctrl+alt+r",
        "mac": "cmd+alt+r"
      },
      {
        "command": "metu.companionTurn",
        "key": "ctrl+alt+a",
        "mac": "cmd+alt+a"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "metu",
          "title": "metu",
          "icon": "$(brain)"
        }
      ]
    },
    "views": {
      "metu": [
        {
          "id": "metu.conductorBacklog",
          "name": "Conductor backlog"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "metu.refreshBacklog",
          "when": "view == metu.conductorBacklog",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "build": "tsc -p .",
    "typecheck": "tsc -p . --noEmit",
    "watch": "tsc -p . -w",
    "package": "pnpm dlx @vscode/vsce@^3.2.1 package --no-dependencies --no-git-tag-version --no-update-package-json -o metu-vscode.vsix",
    "publish": "pnpm dlx @vscode/vsce@^3.2.1 publish --no-dependencies"
  },
  "devDependencies": {
    "@types/vscode": "^1.90.0",
    "@types/node": "catalog:",
    "typescript": "catalog:"
  }
}
