# notai (reference SDK consumer)

# OIDC client registered in metu via /apps "Register app".
# Required scopes for this demo: capture:write, recall:read, notify:write.
METU_ISSUER=http://localhost:24890
METU_CLIENT_ID=metu_app_notai_dev
METU_CLIENT_SECRET=replace-me

# next-auth
AUTH_SECRET=dev-secret-change-me-min-32-chars-long
NEXTAUTH_URL=http://localhost:24896
