{
  "name": "metu",
  "private": true,
  "version": "0.1.0",
  "description": "Personal AI Operating System — external RAM for AI-native founders",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean && rimraf node_modules .turbo",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,yml}\"",
    "prepare": "husky",
    "db:generate": "pnpm --filter @metu/db generate",
    "db:push": "pnpm --filter @metu/db push",
    "db:studio": "pnpm --filter @metu/db studio",
    "db:seed": "pnpm --filter @metu/db seed",
    "tf:plan": "cd infra/terraform && terraform plan",
    "tf:apply": "cd infra/terraform && terraform apply",
    "bootstrap:env": "node scripts/bootstrap-env.mjs",
    "bootstrap:env:force": "node scripts/bootstrap-env.mjs --force",
    "bootstrap:gcp": "pwsh -NoProfile -File ./scripts/bootstrap-gcp.ps1",
    "infra:up": "docker compose up -d --wait && docker compose --profile init up minio-init",
    "infra:down": "docker compose down",
    "infra:reset": "docker compose down -v",
    "infra:logs": "docker compose logs -f",
    "companion:icons": "node scripts/ensure-companion-icon.mjs",
    "companion:build": "pnpm companion:icons && pnpm --filter @metu/companion tauri:build",
    "release:companion": "node scripts/release-companion.mjs",
    "release:companion:minor": "node scripts/release-companion.mjs minor",
    "release:companion:major": "node scripts/release-companion.mjs major",
    "browser-ext:package": "node scripts/package-browser-ext.mjs",
    "browser-ext:package:prod": "node scripts/package-browser-ext.mjs --prod",
    "lint:actions": "node scripts/check-actionlint.mjs --all",
    "lint:workspace-scope": "node scripts/lint-workspace-scope.mjs --strict"
  },
  "devDependencies": {
    "turbo": "catalog:",
    "typescript": "catalog:",
    "prettier": "catalog:",
    "rimraf": "catalog:",
    "@types/node": "catalog:",
    "@resvg/resvg-js": "^2.6.2",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@commitlint/types": "^19.5.0"
  },
  "pnpm": {
    "overrides": {
      "tar@<7.5.7": ">=7.5.7",
      "postcss@<8.5.10": ">=8.5.10",
      "@xmldom/xmldom@<0.8.12": ">=0.8.12",
      "protobufjs@>=8.0.0 <8.0.2": ">=8.0.2",
      "ip-address@<=10.1.0": ">=10.1.1",
      "qs@>=6.11.1 <=6.15.1": ">=6.15.2",
      "uuid@>=7.0.0 <11.1.1": ">=11.1.1",
      "shell-quote@<1.8.4": ">=1.8.4",
      "@grpc/grpc-js@>=1.14.0 <1.14.4": ">=1.14.4",
      "brace-expansion@>=5.0.0 <5.0.6": ">=5.0.6",
      "ws@>=8.0.0 <8.20.1": ">=8.20.1",
      "@opentelemetry/auto-instrumentations-node@<0.75.0": ">=0.75.0",
      "@opentelemetry/sdk-node@<0.217.0": ">=0.217.0",
      "@opentelemetry/exporter-prometheus@<0.217.0": ">=0.217.0"
    }
  }
}
